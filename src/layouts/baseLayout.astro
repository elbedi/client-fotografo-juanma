---
import "../styles/global.css";
import siteConfig from "../config/siteConfig.js";
import Head from "./partials/head.jsx";
import site from "../content/site";
import Header from "./partials/header.jsx";
import Footer from "./partials/footer.jsx";
---

<!doctype html>
<html lang={siteConfig.lang}>
  <Head />
  <body
    class="is-loading bg-background text-on-background font-body antialiased selection:bg-primary-fixed selection:text-on-primary-fixed"
    aria-busy="true">
    <div
      id="page-preloader"
      class="page-preloader"
      role="status"
      aria-live="polite"
      aria-label={`Cargando ${site.name}`}>
      <div class="page-preloader__inner scanline">
        <span class="page-preloader__tag">Inicializando terminal visual</span>
        <p class="page-preloader__title glow-text">{site.name}</p>
        <div class="page-preloader__bar" aria-hidden="true">
          <span class="page-preloader__bar-fill"></span>
        </div>
      </div>
    </div>

    <Header brand={site.name} ctaLabel={site.ctaText} />
    <slot />
    <Footer brand={site.name} email={site.email} phone={site.phone} />

    <script>
      import { initLenis } from "../lib/lenis.js";

      const preloader = document.getElementById("page-preloader");
      const preloaderStartedAt = performance.now();
      const minimumLoaderTime = 1500;
      const maximumLoaderTime = 4500;

      const finishPreloader = () => {
        if (!preloader || preloader.dataset.state === "done") {
          return;
        }

        preloader.dataset.state = "done";
        document.body.classList.remove("is-loading");
        document.body.setAttribute("aria-busy", "false");
        window.setTimeout(() => preloader.remove(), 700);
      };

      const waitForFonts = async () => {
        if (!("fonts" in document)) {
          return;
        }

        await Promise.race([
          document.fonts.ready,
          new Promise((resolve) => window.setTimeout(resolve, 1200)),
        ]);
      };

      const resolvePreloader = async () => {
        await waitForFonts();
        const elapsed = performance.now() - preloaderStartedAt;
        const remaining = Math.max(0, minimumLoaderTime - elapsed);

        window.setTimeout(finishPreloader, remaining);
      };

      window.addEventListener(
        "load",
        () => {
          void resolvePreloader();
        },
        { once: true },
      );

      // Safety guard: never block the page if a resource hangs.
      window.setTimeout(finishPreloader, maximumLoaderTime);

      if (document.readyState === "complete") {
        void resolvePreloader();
      }

      const lenis = initLenis();

      const activeClass = "border-b-2 border-[#ccff00] pb-1 text-[#ccff00]";
      const inactiveClass = "text-white/60 transition-colors hover:text-white";
      const links = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"),
      ).filter((link) => (link.getAttribute("href") || "").startsWith("#"));

      const setActive = (activeHref: string | null) => {
        links.forEach((link) => {
          const isActive =
            !!activeHref && link.getAttribute("href") === activeHref;
          link.dataset.active = isActive ? "true" : "false";
          link.className = isActive ? activeClass : inactiveClass;
          isActive
            ? link.setAttribute("aria-current", "page")
            : link.removeAttribute("aria-current");
        });
      };

      const getSections = () =>
        links
          .map((link) => {
            const href = link.getAttribute("href") || "";
            const section = href
              ? document.querySelector<HTMLElement>(href)
              : null;
            return section ? { href, section } : null;
          })
          .filter(
            (entry): entry is { href: string; section: HTMLElement } => !!entry,
          );

      const updateActiveFromViewport = () => {
        const marker = Math.min(window.innerHeight * 0.35, 260);
        const active = getSections().find(({ section }) => {
          const { top, bottom } = section.getBoundingClientRect();
          return top <= marker && bottom > marker;
        });
        setActive(active?.href ?? null);
      };

      let rafId = 0;
      const scheduleUpdate = () => {
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          rafId = 0;
          updateActiveFromViewport();
        });
      };

      links.forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href") || "";
          const target = href
            ? document.querySelector<HTMLElement>(href)
            : null;
          if (!target) return;

          event.preventDefault();
          lenis?.scrollTo
            ? lenis.scrollTo(target, { offset: -90, duration: 1.2 })
            : target.scrollIntoView({ behavior: "smooth", block: "start" });
          history.replaceState(null, "", href);
          scheduleUpdate();
        });
      });

      window.addEventListener("scroll", scheduleUpdate, { passive: true });
      window.addEventListener("resize", scheduleUpdate, { passive: true });
      window.addEventListener("hashchange", scheduleUpdate);
      window.addEventListener("load", scheduleUpdate, { once: true });

      let retries = 0;
      const waitForSections = () => {
        if (getSections().length || retries++ >= 60) {
          scheduleUpdate();
          return;
        }
        requestAnimationFrame(waitForSections);
      };
      waitForSections();
    </script>
  </body>
</html>
